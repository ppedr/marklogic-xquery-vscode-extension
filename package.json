{
  "name": "marklogic-xquery",
  "displayName": "XQuery + MarkLogic",
  "description": "XQuery language support with MarkLogic 1.0-ml dialect",
  "version": "0.1.0",
  "publisher": "ppfjuni",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/marklogic-xquery/marklogic-xquery-vscode"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "xquery",
        "aliases": [
          "XQuery",
          "xquery",
          "XQuery MarkLogic"
        ],
        "extensions": [
          ".xq",
          ".xqy",
          ".xquery",
          ".xqm",
          ".xql"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "xquery",
        "scopeName": "source.xquery",
        "path": "./syntaxes/xquery.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "xquery",
        "path": "./snippets/xquery.json"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "node esbuild.js --production",
    "compile": "tsc --noEmit",
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "lint": "eslint src --ext ts",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-cli": "^0.0.9",
    "@vscode/test-electron": "^2.3.9",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0"
  }
}
